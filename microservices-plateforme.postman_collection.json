    {
      "name": "🛡️ Administration - Via Gateway",
      "description": "Back-office administrateur. En mode DEV, les requêtes passent même sans token ADMIN. En production, il faudra un token avec role=ADMIN.",
      "item": [
        {
          "name": "Tableau de bord - Statistiques",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
