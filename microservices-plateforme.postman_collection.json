              "mode": "raw",
              "raw": "{\n  \"type\": \"FORMATION\",\n  \"titre\": \"Certification AWS Solutions Architect - Préparation\",\n  \"description\": \"Programme intensif de 8 semaines pour préparer la certification AWS-SAA-C03. Cours du soir + exercices pratiques.\",\n  \"categorie\": \"Cloud\",\n  \"localisation\": \"Douala ou en ligne\",\n  \"medias\": [],\n  \"dateExpiration\": \"2026-09-30\"\n}"
            },
            "url": { "raw": "{{gateway_url}}/api/v1/publications", "host": ["{{gateway_url}}"], "path": ["api","v1","publications"] },
            "description": "Requête authentifiée. Le Gateway extrait les claims du JWT et injecte X-User-Id, X-User-Email, X-User-Nom, X-User-Role."
